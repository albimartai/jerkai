# Copy to .env.local and fill in. Never commit .env.local.
# Neon Postgres connection string (dev branch locally; Vercel sets prod/preview per environment).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Shared secret for the Apple Health ingest endpoint (POST /api/ingest/health).
# Sent by Health Auto Export as an `x-api-key` header. Generate: openssl rand -hex 32
HEALTH_EXPORT_SHARED_SECRET=

# Resend API key — sync-failure alerts now, Auth.js magic links later (same account).
AUTH_RESEND_KEY=

# Destination for same-day sync-failure alert emails.
SYNC_ALERT_EMAIL_TO=you@example.com
