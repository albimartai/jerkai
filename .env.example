# Copy to .env.local and fill in. Never commit .env.local.
# Neon Postgres connection string (dev branch locally; Vercel sets prod/preview per environment).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Shared secret for the Apple Health ingest endpoint (POST /api/ingest/health).
# Sent by Health Auto Export as an `x-api-key` header. Generate: openssl rand -hex 32
HEALTH_EXPORT_SHARED_SECRET=

# Resend API key — sync-failure alerts and Auth.js magic links (same account).
# Auth.js picks this up automatically for the Resend provider (env inference).
AUTH_RESEND_KEY=

# Auth.js session/JWT encryption secret. Generate: openssl rand -base64 32
AUTH_SECRET=

# The only email address allowed to sign in (single-user app).
ALLOWLISTED_EMAIL=you@example.com

# Canonical app URL — pins production magic-link callbacks to the real domain
# instead of a *.vercel.app deployment URL. See auth.ts.
NEXT_PUBLIC_APP_URL=https://jerkai.app

# Destination for same-day sync-failure alert emails.
SYNC_ALERT_EMAIL_TO=you@example.com
