{
  "name": "jerkai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:integration": "vitest run --project integration",
    "migrate": "node-pg-migrate --envPath .env.local up",
    "migrate:ci": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate --envPath .env.local down",
    "migrate:create": "node-pg-migrate create",
    "seed:dev": "node --env-file=.env.local scripts/seed-dev.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@auth/neon-adapter": "^1.11.2",
    "@neondatabase/serverless": "^1.1.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "husky": "^9.1.7",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.22.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
